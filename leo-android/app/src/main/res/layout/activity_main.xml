<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moondust_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/moondust_bg"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/appName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.02"
                    android:text="@string/app_name"
                    android:textColor="@color/moondust_text_primary"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" />

                <ImageView
                    android:id="@+id/settingsBtn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings"
                    android:padding="10dp"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/moondust_text_secondary" />
            </RelativeLayout>

            <TextView
                android:id="@+id/deviceCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/moondust_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Section: Home Control -->
            <TextView
                android:id="@+id/masterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="@string/label_home_control"
                android:textAllCaps="true"
                android:textColor="@color/moondust_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium" />

            <androidx.cardview.widget.CardView
                android:id="@+id/masterControlsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/moondust_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/masterAllOn"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:text="@string/master_all_on"
                        android:textColor="#003135"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/moondust_accent"
                        app:cornerRadius="22dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/masterAllOff"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="5dp"
                        android:layout_weight="1"
                        android:text="@string/master_all_off"
                        android:textColor="@color/moondust_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#21262D"
                        app:cornerRadius="22dp"
                        app:strokeColor="@color/moondust_border"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Devices -->
            <TextView
                android:id="@+id/devicesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:text="@string/label_devices"
                android:textAllCaps="true"
                android:textColor="@color/moondust_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium" />

            <GridLayout
                android:id="@+id/deviceGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="1" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="60dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/not_configured"
                    android:textColor="@color/moondust_text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/not_configured_sub"
                    android:textColor="@color/moondust_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/refresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:text="@string/searching"
        android:textColor="#003135"
        android:textSize="12sp"
        android:textStyle="bold"
        app:backgroundTint="@color/moondust_accent"
        app:icon="@drawable/ic_refresh"
        app:iconTint="#003135"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
